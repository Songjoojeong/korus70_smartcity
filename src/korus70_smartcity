# %% [16c] 정책 what-if 시나리오 — 공통 설정
# 모든 시나리오는 traffic_vuln_eq(교통지점 + tract 형평성)를 기반으로
# '지수 재계산'만 수행한다 (모델 재학습 없음). 따라서 빠르고 투명하다.
import numpy as np

# 원본 보존용 복사본 (시나리오마다 깨끗한 출발점에서 시작)
base = traffic_vuln_eq.drop(columns="geometry").copy().reset_index(drop=True)

# 정규화 함수 (원본 분포 기준으로 고정해 시나리오 간 비교 가능하게 함)
def mm_fixed(s, lo, hi):
    return 0.0 if hi == lo else (s - lo) / (hi - lo)

# 원본 분포의 min/max를 저장 (시나리오가 이 스케일을 공유)
TRAFFIC_LO, TRAFFIC_HI = base["mean_daily_traffic"].min(), base["mean_daily_traffic"].max()
BUS_LO, BUS_HI = base["bus_count_1km"].min(), base["bus_count_1km"].max()

def recompute_index(df):
    """교통량·버스수가 바뀐 df로 vulnerability·composite_vuln을 재계산."""
    df = df.copy()
    df["traffic_burden"]  = df["mean_daily_traffic"].apply(lambda v: mm_fixed(v, TRAFFIC_LO, TRAFFIC_HI))
    df["transit_deficit"] = 1 - df["bus_count_1km"].apply(lambda v: mm_fixed(v, BUS_LO, BUS_HI))
    df["vulnerability"]   = 0.6*df["traffic_burden"] + 0.4*df["transit_deficit"]
    df["composite_vuln"]  = 0.4*df["vulnerability"] + 0.6*df["social_vuln"]
    return df

print("기준선(현재 상태) 복합취약지수 상위 5:")
print(base[["LOCALNAM","county_name","mean_daily_traffic","bus_count_1km",
            "social_vuln","composite_vuln"]]
      .sort_values("composite_vuln", ascending=False).head().to_string(index=False))

# %% [16d] 시나리오 1 — 대중교통 확충 (transit expansion)
# 복합취약지수 상위 N개 지점의 1km 내 버스정류장을 K개 추가하면
# transit_deficit과 composite_vuln이 얼마나 감소하는가?
def scenario_transit_expansion(base, top_n=3, add_stops=10):
    df = base.copy()
    targets = df.sort_values("composite_vuln", ascending=False).head(top_n).index
    df.loc[targets, "bus_count_1km"] = df.loc[targets, "bus_count_1km"] + add_stops
    return recompute_index(df), targets

for k in [5, 10, 20]:
    s1, tgt = scenario_transit_expansion(base, top_n=3, add_stops=k)
    delta = base.loc[tgt, "composite_vuln"].values - s1.loc[tgt, "composite_vuln"].values
    print(f"[정류장 +{k}개, 상위3지점] 평균 복합취약지수 감소: {delta.mean():.3f}")

# 대표 시나리오(+10) 상세 표
s1, tgt = scenario_transit_expansion(base, top_n=3, add_stops=10)
comp = base.loc[tgt, ["LOCALNAM","composite_vuln"]].copy()
comp["composite_vuln_after"] = s1.loc[tgt, "composite_vuln"].values
comp["reduction"] = comp["composite_vuln"] - comp["composite_vuln_after"]
print("\n시나리오1 상세 (정류장 +10):")

# %% [16e] 시나리오 2 — 교통 수요 관리 (traffic demand reduction)
# 재택근무·통행료 등으로 상위 지점의 일교통량을 10/20/30% 감축하면?
def scenario_traffic_reduction(base, top_n=3, pct=0.2):
    df = base.copy()
    targets = df.sort_values("traffic_burden", ascending=False).head(top_n).index
    df.loc[targets, "mean_daily_traffic"] = df.loc[targets, "mean_daily_traffic"] * (1 - pct)
    return recompute_index(df), targets

for p in [0.10, 0.20, 0.30]:
    s2, tgt = scenario_traffic_reduction(base, top_n=3, pct=p)
    delta = base.loc[tgt, "vulnerability"].values - s2.loc[tgt, "vulnerability"].values
    print(f"[교통량 -{int(p*100)}%, 상위3지점] 평균 vulnerability 감소: {delta.mean():.3f}")

s2, _ = scenario_traffic_reduction(base, top_n=3, pct=0.20)
s2.to_csv(OUTPUT_DIR/"scenario2_traffic_reduction.csv", index=False)

# %% [16f] 시나리오 3 — 한정 예산 배분: 효율 우선 vs 형평 우선 (개선판)
# 같은 예산(정류장 K개)을 어디에 투입하느냐로 결과가 어떻게 갈리는지 비교한다.
#   (a) 효율 우선: 교통부담(traffic_burden) 최고 지점에 배분
#   (b) 형평 우선: 사회적 취약성(social_vuln) 최고 지점에 배분
# 측정은 '전체 평균'이 아니라 (1)배분 타깃의 개선폭, (2)가장 취약한 지점의
# 보호 효과로 본다. 전체 평균은 11개 지점에 희석돼 차이가 안 드러나기 때문.

ADD_STOPS = 5   # 현실적인 소규모 확충 (이전 15는 과대)

def allocate(base, mode, add_stops=ADD_STOPS):
    df = base.copy()
    idx = (df["traffic_burden"].idxmax() if mode == "efficiency"
           else df["social_vuln"].idxmax())
    df.loc[idx, "bus_count_1km"] += add_stops
    return recompute_index(df), idx

eff, i_eff = allocate(base, "efficiency")
equ, i_equ = allocate(base, "equity")

# 기준선에서 '가장 취약한 지점'(보호해야 할 대상)
worst_idx = base["composite_vuln"].idxmax()
worst_name = base.loc[worst_idx, "LOCALNAM"]

def summarize(label, scen, target_idx):
    return {
        "allocation": label,
        "target": base.loc[target_idx, "LOCALNAM"],          # 예산 투입 지점
        "target_before": base.loc[target_idx, "composite_vuln"],
        "target_after":  scen.loc[target_idx, "composite_vuln"],
        "target_reduction": base.loc[target_idx, "composite_vuln"] - scen.loc[target_idx, "composite_vuln"],
        # 가장 취약한 지점(worst)이 이 배분으로 얼마나 보호되나
        "worst_after": scen.loc[worst_idx, "composite_vuln"],
        # 전체 취약 인구 보호 관점: 전체 합계(낮을수록 좋음)
        "total_composite": scen["composite_vuln"].sum(),
    }

rows = [
    {"allocation":"baseline","target":"-",
     "target_before":base.loc[worst_idx,"composite_vuln"],
     "target_after":base.loc[worst_idx,"composite_vuln"],
     "target_reduction":0.0,
     "worst_after":base.loc[worst_idx,"composite_vuln"],
     "total_composite":base["composite_vuln"].sum()},
    summarize("efficiency", eff, i_eff),
    summarize("equity",     equ, i_equ),
]
s3 = pd.DataFrame(rows)

print(f"가장 취약한 지점(보호 대상): {worst_name} "
      f"(기준 composite={base.loc[worst_idx,'composite_vuln']:.3f})\n")
print(f"정류장 +{ADD_STOPS}개 배분 비교:")
print(s3.to_string(index=False))

print("\n해석 포인트:")
print(f" • 효율 우선은 {base.loc[i_eff,'LOCALNAM']}(교통최다)에 투입 → "
      f"그 지점만 {s3.loc[1,'target_reduction']:.3f} 개선, "
      f"가장 취약한 {worst_name}은 {s3.loc[1,'worst_after']:.3f}로 그대로.")
print(f" • 형평 우선은 {base.loc[i_equ,'LOCALNAM']}(최취약)에 투입 → "
      f"가장 취약한 지점을 {s3.loc[2,'worst_after']:.3f}로 직접 낮춤.")
print(" • 같은 예산이라도 형평 배분이 '가장 취약한 집단'을 직접 보호한다.")

s3.to_csv(OUTPUT_DIR/"scenario3_allocation.csv", index=False)

# %% [16g] 시나리오 4 — 인구가중 노출 (population-weighted exposure)
# '지점이 취약'을 넘어 '얼마나 많은 사람이 영향받는가'로 환산.
# 각 교통지점이 속한 tract의 인구를 가중치로 사용.

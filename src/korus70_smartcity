def mm(s):
    s = s.astype(float); rng = s.max() - s.min()
    return (s - s.min()) / rng if rng else 0.0

# 1) 먼저 0~1로 정규화된 지표들을 만든다 (순서 중요)
traffic_vuln_eq["poverty"]    = mm(traffic_vuln_eq["pct_poverty"])      # 빈곤율 → 0~1
traffic_vuln_eq["no_vehicle"] = mm(traffic_vuln_eq["pct_no_vehicle"])   # 차량없음 → 0~1
traffic_vuln_eq["low_income"] = 1 - mm(traffic_vuln_eq[COL["medinc"]])  # 소득낮을수록 ↑

# 2) MEDHHINC 결측 tract 보완: low_income이 비면 '정규화된 poverty'로 채운다.
#    (pct_poverty 같은 퍼센트값이 아니라 0~1 스케일의 poverty로 채워야 함)
traffic_vuln_eq["low_income"] = traffic_vuln_eq["low_income"].fillna(
    traffic_vuln_eq["poverty"])

# 3) 사회적 취약성 = 세 지표의 평균 (모두 0~1)
